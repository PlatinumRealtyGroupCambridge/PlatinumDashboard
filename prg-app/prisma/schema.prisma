// Platinum Realty Group Corporate Dashboard — database schema
// Models here replace the in-memory arrays (USERS, SERIES, AGENDA, TASKS, GOALS)
// used in the earlier HTML prototype, with a real relational schema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum MeetingType {
  ONE_ON_ONE
  TEAM
  OWNERSHIP
}

enum GoalStatus {
  GOOD
  WARN
  CRIT
}

// Simple key/value store for one-off app bookkeeping — currently used to
// gate a one-time re-seed of the meeting schedule (see prisma/seed.ts).
model AppMeta {
  key   String @id
  value String
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String
  initials  String
  color     String
  createdAt DateTime @default(now())

  // --- per-user login & permissions ---
  // Null until an admin sets a password for this person (see
  // prisma/seed.ts and app/api/admin/users) — a user with no passwordHash
  // cannot log in yet.
  passwordHash String?

  // Admins can log into the admin panel (app/(app)/admin/users), always
  // see every KPI dashboard regardless of allowedSections, and always see
  // every meeting series regardless of participation.
  isAdmin Boolean @default(false)

  // Which of the 7 KPI dashboards (lib/sections.ts DASHBOARD_SECTIONS ids,
  // e.g. "financial", "leasing") this person is allowed to view. Ignored
  // for admins. Meeting Management / To-Dos / Goals are not gated by this
  // list — everyone with a login can use those (Meeting Management is
  // separately scoped to each person's own meetings, see
  // lib/get-meeting-data.ts).
  allowedSections String[] @default([])

  // Bumped whenever an admin resets this user's password (or the user is
  // otherwise force-logged-out), so any session cookie signed before the
  // bump is rejected on the next request even if it hasn't expired yet —
  // see verifySession()/createUserSession() in lib/auth.ts.
  sessionVersion Int @default(0)

  // 1-on-1 series where this user is the "owner" (the non-Tim participant),
  // used to label the series (e.g. "1-on-1: Matt")
  oneOnOneSeries MeetingSeries[] @relation("OneOnOneOwner")

  participantOf  MeetingParticipant[]
  agendaItemsAdded AgendaItem[]        @relation("AgendaAddedBy")
  tasksAssigned  Task[]               @relation("TaskAssignee")
  tasksCreated   Task[]               @relation("TaskCreatedBy")
  goalsAssigned  Goal[]               @relation("GoalAssignee")
  goalsCreated   Goal[]               @relation("GoalCreatedBy")
  chatFollowUps  ChatFollowUp[]
}

// Tracks a just-created task/goal that the Google Chat bot asked the sender
// a follow-up question about (e.g. "did you want to give this a due
// date?"), so that if their next message just answers the question (e.g.
// "next Friday", "no rush") the bot can apply it to that item instead of
// creating a confusing new one. Cleared once resolved, replaced whenever a
// newer item is created, and ignored by the bot once it's more than 30
// minutes old.
model ChatFollowUp {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemType  String   // "task" | "goal"
  itemId    String
  itemTitle String
  createdAt DateTime @default(now())
}

model MeetingSeries {
  id            String      @id @default(cuid())
  type          MeetingType
  name          String
  durationMins  Int
  color         String

  // set only for ONE_ON_ONE series, points at the non-Tim participant
  ownerId       String?
  owner         User?       @relation("OneOnOneOwner", fields: [ownerId], references: [id])

  participants  MeetingParticipant[]
  instances     MeetingInstance[]

  createdAt     DateTime    @default(now())
}

model MeetingParticipant {
  id        String        @id @default(cuid())
  seriesId  String
  series    MeetingSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id])

  @@unique([seriesId, userId])
}

model MeetingInstance {
  id          String        @id @default(cuid())
  seriesId    String
  series      MeetingSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  startsAt    DateTime
  // true if this instance was created as the "next occurrence" target of a
  // tabled item from a prior instance in the same series
  agendaItems AgendaItem[]

  createdAt   DateTime      @default(now())

  @@index([seriesId, startsAt])
}

model AgendaItem {
  id            String          @id @default(cuid())
  instanceId    String
  instance      MeetingInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  title         String
  discussed     Boolean         @default(false)
  notes         String          @default("")
  order         Int             @default(0)

  addedById     String?
  addedBy       User?           @relation("AgendaAddedBy", fields: [addedById], references: [id])

  // true if this item was carried forward ("tabled") from a previous
  // occurrence of the same meeting series into its current instance
  tabled        Boolean         @default(false)

  // if this agenda item was itself raised from an existing task/goal via
  // "Add to meeting", these record the source
  sourceType    String?         // "task" | "goal"
  sourceTaskId  String?
  sourceTask    Task?           @relation("AgendaFromTask", fields: [sourceTaskId], references: [id])
  sourceGoalId  String?
  sourceGoal    Goal?           @relation("AgendaFromGoal", fields: [sourceGoalId], references: [id])

  tasks         Task[]          @relation("TaskFromAgendaItem")

  createdAt     DateTime        @default(now())
}

model Task {
  id             String       @id @default(cuid())
  title          String
  notes          String       @default("")
  done           Boolean      @default(false)
  dueDate        DateTime?

  // Archiving happens either explicitly (the Delete button) or
  // automatically when the task is checked off as done.
  archived       Boolean      @default(false)
  archivedAt     DateTime?

  assigneeId     String?
  assignee       User?        @relation("TaskAssignee", fields: [assigneeId], references: [id])

  createdById    String?
  createdBy      User?        @relation("TaskCreatedBy", fields: [createdById], references: [id])

  // the agenda item this task was created from, if any
  agendaItemId   String?
  agendaItem     AgendaItem?  @relation("TaskFromAgendaItem", fields: [agendaItemId], references: [id])

  // agenda items raised from this task via "Add to meeting"
  meetingRefs    AgendaItem[] @relation("AgendaFromTask")

  // the goal this task is a sub-task of, if any (see Goal.subtasks) — a
  // goal is considered achieved once all of its non-archived sub-tasks are
  // done, recomputed in lib/goal-progress.ts whenever a sub-task changes
  goalId         String?
  goal           Goal?        @relation("GoalSubtasks", fields: [goalId], references: [id])

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Goal {
  id             String       @id @default(cuid())
  title          String
  notes          String       @default("")
  status         GoalStatus   @default(GOOD)
  dueDate        DateTime?

  // Goals get the same "checked off as complete" treatment as tasks —
  // done also implies archived (see the archiving note on Task above).
  done           Boolean      @default(false)
  archived       Boolean      @default(false)
  archivedAt     DateTime?

  assigneeId     String?
  assignee       User?        @relation("GoalAssignee", fields: [assigneeId], references: [id])

  createdById    String?
  createdBy      User?        @relation("GoalCreatedBy", fields: [createdById], references: [id])

  meetingRefs    AgendaItem[] @relation("AgendaFromGoal")

  // sub-tasks that make up this goal — see Task.goalId and
  // lib/goal-progress.ts for how these drive the goal's progress bar and
  // auto-completion
  subtasks       Task[]       @relation("GoalSubtasks")

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}
